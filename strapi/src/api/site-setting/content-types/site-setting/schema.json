{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Settings",
    "description": "Global site settings: brand, contact info, hero content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "brandName": {
      "type": "string",
      "required": true,
      "default": "HORIZON"
    },
    "heroTagline": {
      "type": "text",
      "required": true
    },
    "heroCtaText": {
      "type": "string",
      "required": true,
      "default": "Book your adventure today"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "location": {
      "type": "string",
      "required": true
    },
    "footerDescription": {
      "type": "text",
      "required": true
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "site.social-link"
    }
  }
}
